# NEXUS — Raspberry Pi Environment
# Platform: ARM64 (Raspberry Pi 4/5 with 4GB+ RAM)
# IMPORTANT: Uses reduced resource limits and lighter models
#
# Copy to .env and fill in real values before deploying

# ── Database ──
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_MAXMEMORY=128mb

# ── LLM API Keys ──
# Option A: Use cloud LLMs (requires internet)
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-api-key-here
# Option B: Use local Ollama (no API keys needed, but slower on Pi)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ── Agent Model Assignments (use lighter/cheaper models on Pi) ──
# Cloud models (default — uses API calls)
MODEL_CEO=claude-haiku-4-5-20251001
MODEL_ENGINEER=claude-haiku-4-5-20251001
MODEL_ANALYST=gemini-2.0-flash
MODEL_WRITER=gemini-2.0-flash
MODEL_QA=gemini-2.0-flash
MODEL_PROMPT_CREATOR=claude-haiku-4-5-20251001
# Local Ollama models (uncomment to use local inference)
# MODEL_CEO=ollama/llama3.1:8b
# MODEL_ENGINEER=ollama/llama3.1:8b
# MODEL_ANALYST=ollama/llama3.1:8b
# MODEL_WRITER=ollama/llama3.1:8b
# MODEL_QA=ollama/llama3.1:8b
# MODEL_PROMPT_CREATOR=ollama/llama3.1:8b

# ── Cost Controls ──
DAILY_SPEND_LIMIT_USD=2.00
DEFAULT_TOKEN_BUDGET_PER_TASK=20000

# ── Auth ──
JWT_SECRET_KEY=CHANGE_ME_generate_a_strong_secret

# ── Application ──
LOG_LEVEL=WARNING

# ── Ports ──
BACKEND_PORT=8000
FRONTEND_PORT=80

# ── Resource Limits (Raspberry Pi 4: 4GB or 8GB RAM) ──
# Tuned for 4GB Pi — increase if you have 8GB
POSTGRES_MEMORY_LIMIT=512m
REDIS_MEMORY_LIMIT=256m
KAFKA_MEMORY_LIMIT=512m
KAFKA_HEAP_OPTS=-Xmx256m -Xms128m
BACKEND_MEMORY_LIMIT=512m
FRONTEND_MEMORY_LIMIT=128m

# ── Docker Images (ARM64 multi-arch) ──
# BACKEND_IMAGE=ghcr.io/santapong/nexus-backend:latest
# FRONTEND_IMAGE=ghcr.io/santapong/nexus-frontend:latest

# ── Temporal — DISABLED on Pi by default (resource heavy) ──
# Enable only on 8GB Pi: docker compose --profile temporal up
TEMPORAL_MEMORY_LIMIT=256m
