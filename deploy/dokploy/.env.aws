# NEXUS — AWS EC2 / Lightsail / ECS Environment
# Platform: AWS (amd64)
# Recommended instance: t3.medium (2 vCPU, 4GB RAM) or larger
#
# Copy to .env and fill in real values before deploying

# ── Database ──
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_MAXMEMORY=512mb

# ── LLM API Keys ──
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ── Agent Model Assignments ──
MODEL_CEO=claude-sonnet-4-20250514
MODEL_ENGINEER=claude-sonnet-4-20250514
MODEL_ANALYST=gemini-2.0-flash
MODEL_WRITER=claude-haiku-4-5-20251001
MODEL_QA=claude-haiku-4-5-20251001
MODEL_PROMPT_CREATOR=claude-sonnet-4-20250514

# ── Cost Controls ──
DAILY_SPEND_LIMIT_USD=5.00
DEFAULT_TOKEN_BUDGET_PER_TASK=50000

# ── Auth ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_strong_secret

# ── Application ──
LOG_LEVEL=INFO

# ── Ports ──
BACKEND_PORT=8000
FRONTEND_PORT=80

# ── Resource Limits (AWS t3.medium: 4GB RAM) ──
POSTGRES_MEMORY_LIMIT=1g
REDIS_MEMORY_LIMIT=512m
KAFKA_MEMORY_LIMIT=1g
KAFKA_HEAP_OPTS=-Xmx512m -Xms256m
BACKEND_MEMORY_LIMIT=1g
FRONTEND_MEMORY_LIMIT=256m

# ── Docker Images (use pre-built for faster deploys) ──
# BACKEND_IMAGE=ghcr.io/santapong/nexus-backend:latest
# FRONTEND_IMAGE=ghcr.io/santapong/nexus-frontend:latest

# ── Temporal (enable with: docker compose --profile temporal up) ──
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=nexus
TEMPORAL_TASK_QUEUE=nexus-tasks
TEMPORAL_MEMORY_LIMIT=512m

# ── LangFuse (optional) ──
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
