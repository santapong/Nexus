# NEXUS Environment Variables
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev@localhost:5432/nexus

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# LLM API Keys — set the ones you need, leave others empty
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Local / custom model endpoints
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENAI_COMPAT_BASE_URL=http://localhost:8080/v1
OPENAI_COMPAT_API_KEY=

# Cost Controls
DAILY_SPEND_LIMIT_USD=5.00
DEFAULT_TOKEN_BUDGET_PER_TASK=50000

# Application
APP_ENV=development
LOG_LEVEL=INFO
